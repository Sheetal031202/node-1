    <style>
        :root {
            --primary-1: #2c6bed; /* your theme color */
        }

        .school-footer {
            background-color: var(--primary-1);
            color: #ffffff;
        }

        .school-footer a {
            color: #ffffff;
            text-decoration: none;
            font-size: 15px;
        }

        .school-footer a:hover {
            color: #ffd966;
            text-decoration: underline;
        }

        .footer-title {
            font-weight: 600;
            margin-bottom: 10px;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.3);
            margin-top: 20px;
            padding-top: 10px;
            font-size: 14px;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

  

    <!-- FOOTER -->
    <footer class="school-footer pt-4 mt-auto">
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-3">
                    <h5 class="footer-title">ABC Public School</h5>
                    <p>Shaping young minds with knowledge, discipline, and values.</p>
                    <p>
                        📍 Ahmedabad, Gujarat<br>
                        📞 +91 98765 43210<br>
                        ✉️ info@abcschool.com
                    </p>
                </div>

                <div class="col-md-4 mb-3">
                    <h5 class="footer-title">Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Home</a></li>
                        <li><a href="#">About School</a></li>
                        <li><a href="#">Admissions</a></li>
                        <li><a href="#">Academics</a></li>
