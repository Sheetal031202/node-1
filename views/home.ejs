<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>HomePage</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f5f7fb;
        }

        .page-title {
            font-weight: 600;
            color: var(--primary-1);
        }

        .form-card {
            max-width: 500px;
            margin: auto;
            border-radius: 12px;
        }

        label {
            font-weight: 500;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- Navbar -->
    <%- include("navbar") %>

    <!-- Page Content -->
    <main class="flex-fill">
        <div class="container my-5">

            <h2 class="text-center page-title mb-4">Student Registration</h2>

            <div class="card shadow-sm form-card">
                <div class="card-body p-4">

                    <form action="/addpost" method="post">

                        <div class="mb-3">
                            <label class="form-label">Student Name</label>
                            <input type="text" name="name" class="form-control" placeholder="Enter student name" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Standard</label>
                            <input type="text" name="std" class="form-control" placeholder="Enter standard" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Division</label>
                            <input type="text" name="div" class="form-control" placeholder="Enter division" required>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                Add Student
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </main>

    <!-- Footer -->
    <%- include("footer") %>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
